<?xml version="1.0" encoding="utf-8"?>
<!--
  Campaign++ — Custom Trade Items
  Slaves: A Goods-type trade item representing enslaved captives.
    - Gained during village raids (B1071_SlaveEconomyBehavior, ItemsLooted + MapEvent.IsRaid)
    - Gained by converting non-hero prisoners at any town via the "Enslave prisoners" menu option
    - Sold via the standard town Trade screen (civilian market)
    - While present in a town's ItemRoster, provides daily construction/prosperity/manpower bonuses
    - item_category="b1071_slaves" (custom luxury trade good – visible to AI caravan routes)
-->
<Items>
  <Item
    id="b1071_slave"
    name="{=b1071_item_slaves}Slaves"
    mesh="bd_barrel_a"
    item_category="b1071_slaves"
    value="300"
    weight="5"
    Type="Goods">
    <Flags
      Civilian="true" />
  </Item>
</Items>
