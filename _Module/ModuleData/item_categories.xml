<?xml version="1.0" encoding="utf-8"?>
<!--
  Campaign++ — Custom Item Categories
  b1071_slaves: Trade good category for the slave economy system.

  IMPORTANT: XML-loaded ItemCategory demand values are set as raw floats directly
  on the BaseDemand/LuxuryDemand properties. Code-registered vanilla categories
  pass integers to InitializeObject() which multiplies by 0.001f internally.
  This means XML values must already be in the 0.001-scale float range.

  Vanilla luxury goods for reference (decompiled from DefaultItemCategories):
    Wine:    BaseDemand=0.015, LuxuryDemand=0.030
    Velvet:  BaseDemand=0.015, LuxuryDemand=0.032
    Jewelry: BaseDemand=0.015, LuxuryDemand=0.032
    Fur:     BaseDemand=0.010, LuxuryDemand=0.038
    Silver:  BaseDemand=0.010, LuxuryDemand=0.020
    Tools:   BaseDemand=0.030, LuxuryDemand=0.030
    Grain:   BaseDemand=0.140, LuxuryDemand=0.000

  base_demand:    Daily consumption rate by the town market. Controls how fast
                  stock decays (price recovery speed). 0.015 = luxury tier
                  (same as wine/velvet). Higher = faster consumption = larger
                  price differentials between towns.

  luxury_demand:  Signals to AI caravan trade routes that this item has luxury-tier
                  value. 0.032 = same as jewelry/velvet. Caravans optimize for
                  luxury goods, so this value directly activates caravan interest.
-->
<ItemCategories>
  <ItemCategory
    id="b1071_slaves"
    name="{=b1071_slaves_cat}Slaves"
    base_demand="0.015"
    luxury_demand="0.032"
    is_trade_good="true"
    is_animal="false"
    is_valid="true" />
</ItemCategories>
