<Prefab>
  <Window>
    <!-- Full-screen input-blocking overlay with dark tint -->
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
            DoNotPassEventsToChildren="false">
      <Children>

        <!-- Dark background tint (matches native #000000AA) -->
        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                Sprite="BlankWhiteSquare_9" Color="#000000AA" DoNotAcceptEvents="true" />

        <!-- Main panel — centered, 820 x 650 -->
        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                SuggestedWidth="820" SuggestedHeight="650"
                HorizontalAlignment="Center" VerticalAlignment="Center">
          <Children>

            <!-- Panel frame (encyclopedia-style) -->
            <BrushWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                         Brush="Encyclopedia.Frame" DoNotAcceptEvents="true" />
            <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                    MarginLeft="5" MarginRight="5" MarginTop="5" MarginBottom="5"
                    Sprite="Encyclopedia\canvas" DoNotAcceptEvents="true" />

            <!-- Inner content -->
            <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                       MarginLeft="35" MarginRight="20" MarginTop="16" MarginBottom="16"
                       StackLayout.LayoutMethod="VerticalBottomToTop">
              <Children>

                <!-- ===== TITLE BAR ===== -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="42" MarginRight="15">
                  <Children>
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Brush="Encyclopedia.SubPage.Element.Name.Text"
                                Brush.FontSize="24" Brush.FontColor="#E8DBBFFF"
                                Brush.TextHorizontalAlignment="Center"
                                Brush.TextVerticalAlignment="Center"
                                Text="@TitleText" />
                    <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                                  SuggestedWidth="32" SuggestedHeight="32"
                                  HorizontalAlignment="Right" VerticalAlignment="Center"
                                  Brush="Encyclopedia.FilterListButton"
                                  DoNotPassEventsToChildren="true"
                                  UpdateChildrenStates="true"
                                  Command.Click="ExecuteClose">
                      <Children>
                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                    Brush="Encyclopedia.SubPage.Element.Name.Text"
                                    Brush.FontSize="18" Brush.FontColor="#D0C2A5FF"
                                    Brush.TextHorizontalAlignment="Center"
                                    Brush.TextVerticalAlignment="Center"
                                    Text="X" />
                      </Children>
                    </ButtonWidget>
                  </Children>
                </Widget>

                <!-- Divider -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="2" MarginTop="6" MarginBottom="8"
                        Sprite="Encyclopedia\list_divider" AlphaFactor="0.85" />

                <!-- ===== STATS ROW: Gold + Manpower ===== -->
                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                           MarginBottom="8"
                           StackLayout.LayoutMethod="HorizontalLeftToRight">
                  <Children>
                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="16" Brush.FontColor="#D4B870FF"
                                Brush.TextHorizontalAlignment="Left"
                                Text="Gold: " />
                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="16" Brush.FontColor="#FFD700FF"
                                Brush.TextHorizontalAlignment="Left"
                                Text="@GoldText" />
                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                            SuggestedWidth="40" SuggestedHeight="1" />
                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="16" Brush.FontColor="#D4B870FF"
                                Brush.TextHorizontalAlignment="Left"
                                Text="Manpower: " />
                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="16" Brush.FontColor="#88CC88FF"
                                Brush.TextHorizontalAlignment="Left"
                                Text="@ManpowerText" />
                  </Children>
                </ListPanel>

                <!-- Divider -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="1" MarginBottom="3"
                        Sprite="Encyclopedia\list_divider" AlphaFactor="0.62" />

                <!-- ===== ELITE TROOPS SECTION ===== -->
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                            MarginBottom="8"
                            Brush="Encyclopedia.SubPage.Element.Name.Text"
                            Brush.FontSize="17" Brush.FontColor="#99BBFFFF"
                            Brush.TextHorizontalAlignment="Left"
                            Text="Elite Troops (Culture Pool)"
                            IsVisible="@HasEliteTroops" />

                <!-- Column headers for Elite section -->
                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                           MarginBottom="4"
                           StackLayout.LayoutMethod="HorizontalLeftToRight"
                           IsVisible="@HasEliteTroops">
                  <Children>
                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                SuggestedWidth="310"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Left"
                                Text="Troop" />
                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                SuggestedWidth="60"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Center"
                                Text="Tier" />
                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                SuggestedWidth="60"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Center"
                                Text="Count" />
                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                SuggestedWidth="100"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Center"
                                Text="Gold Cost" />
                    <!-- Spacer for Recruit button column -->
                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                            SuggestedWidth="80" SuggestedHeight="1" />
                  </Children>
                </ListPanel>

                <!-- Elite troop rows (scrollable container: 5 rows × 29px = 145px) -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="145" IsVisible="@HasEliteTroops">
                  <Children>
                    <ScrollbarWidget Id="EliteScrollbar" HeightSizePolicy="StretchToParent" WidthSizePolicy="Fixed"
                                     SuggestedWidth="8" AlignmentAxis="Vertical"
                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                     MinValue="0" MaxValue="100"
                                     MarginTop="2" MarginBottom="2"
                                     Sprite="scrollbar_9" Handle="EliteScrollbarHandle">
                      <Children>
                        <Widget Id="EliteScrollbarHandle" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                                SuggestedWidth="8" SuggestedHeight="40"
                                HorizontalAlignment="Right" Sprite="scroll_button_9" />
                      </Children>
                    </ScrollbarWidget>
                    <ScrollablePanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                     MouseScrollAxis="Vertical"
                                     VerticalScrollbar="..\EliteScrollbar"
                                     AutoHideScrollBars="true"
                                     MarginRight="14"
                                     ClipRect="EliteClipRect"
                                     InnerPanel="EliteClipRect\EliteInnerPanel">
                      <Children>
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Id="EliteClipRect" ClipContents="true">
                          <Children>
                            <ListPanel DataSource="{EliteTroops}"
                                       Id="EliteInnerPanel"
                                       WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                       StackLayout.LayoutMethod="VerticalBottomToTop">
                              <ItemTemplate>
                                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                           SuggestedHeight="28" MarginBottom="1"
                                           StackLayout.LayoutMethod="HorizontalLeftToRight">
                                  <Children>
                                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                SuggestedWidth="310"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="15"
                                                Brush.TextHorizontalAlignment="Left"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@Name" />
                                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                SuggestedWidth="60"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="15"
                                                Brush.TextHorizontalAlignment="Center"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@Tier" />
                                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                SuggestedWidth="60"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="15"
                                                Brush.TextHorizontalAlignment="Center"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@Count" />
                                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                SuggestedWidth="100"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="15" Brush.FontColor="#FFD700FF"
                                                Brush.TextHorizontalAlignment="Center"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@GoldCost" />
                                    <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                                                  SuggestedWidth="80" SuggestedHeight="24"
                                                  VerticalAlignment="Center"
                                                  Brush="Encyclopedia.FilterListButton"
                                                  DoNotPassEventsToChildren="true"
                                                  UpdateChildrenStates="true"
                                                  IsEnabled="@CanRecruit"
                                                  Command.Click="ExecuteRecruit">
                                      <Children>
                                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                    Brush="Encyclopedia.SubPage.Element.Name.Text"
                                                    Brush.FontSize="13" Brush.FontColor="#99BBFFFF"
                                                    Brush.TextHorizontalAlignment="Center"
                                                    Brush.TextVerticalAlignment="Center"
                                                    Text="Recruit" />
                                      </Children>
                                    </ButtonWidget>
                                  </Children>
                                </ListPanel>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>
                  </Children>
                </Widget>

                <!-- Empty-state for Elite (fixed height matches filled section) -->
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                            SuggestedHeight="195"
                            Brush="Encyclopedia.SubPage.History.Text"
                            Brush.FontSize="14" Brush.FontColor="#9F947DFF"
                            Brush.TextHorizontalAlignment="Center"
                            Brush.TextVerticalAlignment="Center"
                            Text="No elite troops available. Pool regenerates daily from castle manpower."
                            IsVisible="@HasNoEliteTroops" />

                <!-- Divider between Elite and Ready sections -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="1" MarginTop="4" MarginBottom="4"
                        Sprite="Encyclopedia\list_divider" AlphaFactor="0.62" />

                <!-- ===== READY TO RECRUIT SECTION ===== -->
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                            MarginBottom="8"
                            Brush="Encyclopedia.SubPage.Element.Name.Text"
                            Brush.FontSize="17" Brush.FontColor="#88DD88FF"
                            Brush.TextHorizontalAlignment="Left"
                            Text="Ready to Recruit (Prisoners)"
                            IsVisible="@HasAvailableTroops" />

                <!-- Column headers for Ready section -->
                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                           MarginBottom="4"
                           StackLayout.LayoutMethod="HorizontalLeftToRight"
                           IsVisible="@HasAvailableTroops">
                  <Children>
                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                SuggestedWidth="310"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Left"
                                Text="Troop" />
                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                SuggestedWidth="60"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Center"
                                Text="Tier" />
                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                SuggestedWidth="60"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Center"
                                Text="Count" />
                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                SuggestedWidth="100"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Center"
                                Text="Gold Cost" />
                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                            SuggestedWidth="80" SuggestedHeight="1" />
                  </Children>
                </ListPanel>

                <!-- Ready troop rows (scrollable container: 4 rows × 29px = 116px) -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="116" IsVisible="@HasAvailableTroops">
                  <Children>
                    <ScrollbarWidget Id="ReadyScrollbar" HeightSizePolicy="StretchToParent" WidthSizePolicy="Fixed"
                                     SuggestedWidth="8" AlignmentAxis="Vertical"
                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                     MinValue="0" MaxValue="100"
                                     MarginTop="2" MarginBottom="2"
                                     Sprite="scrollbar_9" Handle="ReadyScrollbarHandle">
                      <Children>
                        <Widget Id="ReadyScrollbarHandle" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                                SuggestedWidth="8" SuggestedHeight="40"
                                HorizontalAlignment="Right" Sprite="scroll_button_9" />
                      </Children>
                    </ScrollbarWidget>
                    <ScrollablePanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                     MouseScrollAxis="Vertical"
                                     VerticalScrollbar="..\ReadyScrollbar"
                                     AutoHideScrollBars="true"
                                     MarginRight="14"
                                     ClipRect="ReadyClipRect"
                                     InnerPanel="ReadyClipRect\ReadyInnerPanel">
                      <Children>
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Id="ReadyClipRect" ClipContents="true">
                          <Children>
                            <ListPanel DataSource="{AvailableTroops}"
                                       Id="ReadyInnerPanel"
                                       WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                       StackLayout.LayoutMethod="VerticalBottomToTop">
                              <ItemTemplate>
                                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                           SuggestedHeight="28" MarginBottom="1"
                                           StackLayout.LayoutMethod="HorizontalLeftToRight">
                                  <Children>
                                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                SuggestedWidth="310"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="15"
                                                Brush.TextHorizontalAlignment="Left"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@Name" />
                                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                SuggestedWidth="60"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="15"
                                                Brush.TextHorizontalAlignment="Center"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@Tier" />
                                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                SuggestedWidth="60"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="15"
                                                Brush.TextHorizontalAlignment="Center"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@Count" />
                                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                SuggestedWidth="100"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="15" Brush.FontColor="#FFD700FF"
                                                Brush.TextHorizontalAlignment="Center"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@GoldCost" />
                                    <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                                                  SuggestedWidth="80" SuggestedHeight="24"
                                                  VerticalAlignment="Center"
                                                  Brush="Encyclopedia.FilterListButton"
                                                  DoNotPassEventsToChildren="true"
                                                  UpdateChildrenStates="true"
                                                  IsEnabled="@CanRecruit"
                                                  Command.Click="ExecuteRecruit">
                                      <Children>
                                        <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                    Brush="Encyclopedia.SubPage.Element.Name.Text"
                                                    Brush.FontSize="13" Brush.FontColor="#88DD88FF"
                                                    Brush.TextHorizontalAlignment="Center"
                                                    Brush.TextVerticalAlignment="Center"
                                                    Text="Recruit" />
                                      </Children>
                                    </ButtonWidget>
                                  </Children>
                                </ListPanel>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>
                  </Children>
                </Widget>

                <!-- Empty-state for Ready (fixed height matches filled section) -->
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                            SuggestedHeight="165"
                            Brush="Encyclopedia.SubPage.History.Text"
                            Brush.FontSize="14" Brush.FontColor="#9F947DFF"
                            Brush.TextHorizontalAlignment="Center"
                            Brush.TextVerticalAlignment="Center"
                            Text="No prisoners ready for recruitment."
                            IsVisible="@HasNoAvailableTroops" />

                <!-- Divider between sections -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                        SuggestedHeight="1" MarginTop="4" MarginBottom="4"
                        Sprite="Encyclopedia\list_divider" AlphaFactor="0.62" />

                <!-- ===== PENDING SECTION ===== -->
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                            MarginBottom="8"
                            Brush="Encyclopedia.SubPage.Element.Name.Text"
                            Brush.FontSize="17" Brush.FontColor="#DDCC88FF"
                            Brush.TextHorizontalAlignment="Left"
                            Text="Pending (Training)"
                            IsVisible="@HasPendingTroops" />

                <!-- Column headers for Pending section -->
                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                           MarginBottom="4"
                           StackLayout.LayoutMethod="HorizontalLeftToRight"
                           IsVisible="@HasPendingTroops">
                  <Children>
                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                SuggestedWidth="310"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Left"
                                Text="Troop" />
                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                SuggestedWidth="60"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Center"
                                Text="Tier" />
                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="CoverChildren"
                                SuggestedWidth="60"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Center"
                                Text="Count" />
                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                Brush="Encyclopedia.SubPage.History.Text"
                                Brush.FontSize="13" Brush.FontColor="#9F947DFF"
                                Brush.TextHorizontalAlignment="Right"
                                Text="Status" />
                  </Children>
                </ListPanel>

                <!-- Pending troop rows (scrollable container) -->
                <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                        IsVisible="@HasPendingTroops">
                  <Children>
                    <ScrollbarWidget Id="PendingScrollbar" HeightSizePolicy="StretchToParent" WidthSizePolicy="Fixed"
                                     SuggestedWidth="8" AlignmentAxis="Vertical"
                                     HorizontalAlignment="Right" VerticalAlignment="Top"
                                     MinValue="0" MaxValue="100"
                                     MarginTop="2" MarginBottom="2"
                                     Sprite="scrollbar_9" Handle="PendingScrollbarHandle">
                      <Children>
                        <Widget Id="PendingScrollbarHandle" WidthSizePolicy="Fixed" HeightSizePolicy="Fixed"
                                SuggestedWidth="8" SuggestedHeight="40"
                                HorizontalAlignment="Right" Sprite="scroll_button_9" />
                      </Children>
                    </ScrollbarWidget>
                    <ScrollablePanel WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                     MouseScrollAxis="Vertical"
                                     VerticalScrollbar="..\PendingScrollbar"
                                     AutoHideScrollBars="true"
                                     MarginRight="14"
                                     ClipRect="PendingClipRect"
                                     InnerPanel="PendingClipRect\PendingInnerPanel">
                      <Children>
                        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                Id="PendingClipRect" ClipContents="true">
                          <Children>
                            <ListPanel DataSource="{PendingTroops}"
                                       Id="PendingInnerPanel"
                                       WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren"
                                       StackLayout.LayoutMethod="VerticalBottomToTop">
                              <ItemTemplate>
                                <ListPanel WidthSizePolicy="StretchToParent" HeightSizePolicy="Fixed"
                                           SuggestedHeight="28" MarginBottom="1"
                                           StackLayout.LayoutMethod="HorizontalLeftToRight">
                                  <Children>
                                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                SuggestedWidth="310"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="15"
                                                Brush.TextHorizontalAlignment="Left"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@Name" />
                                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                SuggestedWidth="60"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="15"
                                                Brush.TextHorizontalAlignment="Center"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@Tier" />
                                    <TextWidget WidthSizePolicy="Fixed" HeightSizePolicy="StretchToParent"
                                                SuggestedWidth="60"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="15"
                                                Brush.TextHorizontalAlignment="Center"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@Count" />
                                    <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                                                Brush="Encyclopedia.SubPage.History.Text"
                                                Brush.FontSize="14" Brush.FontColor="#DDCC88FF"
                                                Brush.TextHorizontalAlignment="Right"
                                                Brush.TextVerticalAlignment="Center"
                                                Text="@StatusText" />
                                  </Children>
                                </ListPanel>
                              </ItemTemplate>
                            </ListPanel>
                          </Children>
                        </Widget>
                      </Children>
                    </ScrollablePanel>
                  </Children>
                </Widget>

                <!-- Empty-state for Pending (stretches to fill remaining space) -->
                <TextWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent"
                            Brush="Encyclopedia.SubPage.History.Text"
                            Brush.FontSize="14" Brush.FontColor="#9F947DFF"
                            Brush.TextHorizontalAlignment="Center"
                            Brush.TextVerticalAlignment="Center"
                            Text="No prisoners pending."
                            IsVisible="@HasNoPendingTroops" />

              </Children>
            </ListPanel>

          </Children>
        </Widget>

      </Children>
    </Widget>
  </Window>
</Prefab>
